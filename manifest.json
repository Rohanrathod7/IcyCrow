{
  "manifest_version": 3,
  "name": "IcyCrow",
  "version": "0.1.0",
  "description": "Privacy-first AI tab intelligence.",
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "storage",
    "activeTab"
  ]
}